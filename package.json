{
  "name": "open-mobile-mcp",
  "version": "1.1.3",
  "description": "MCP server for Android and iOS mobile automation — control devices, read logs, and test React Native / Expo apps with LLMs.",
  "type": "module",
  "main": "build/index.js",
  "bin": {
    "open-mobile-mcp": "build/index.js"
  },
  "files": [
    "build/",
    "assets/",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/xzaleksey/open-mobile-mcp.git"
  },
  "homepage": "https://github.com/xzaleksey/open-mobile-mcp#readme",
  "bugs": {
    "url": "https://github.com/xzaleksey/open-mobile-mcp/issues"
  },
  "keywords": [
    "mcp", "model-context-protocol", "mobile", "android", "ios",
    "react-native", "expo", "automation", "adb", "testing", "claude"
  ],
  "scripts": {
    "clean": "rimraf build",
    "prebuild": "npm run clean",
    "build": "tsc",
    "start": "node build/index.js",
    "watch": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "author": "Antigravity",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.1",
    "jimp": "^0.22.10",
    "pixelmatch": "^5.3.0",
    "pngjs": "^7.0.0",
    "tesseract.js": "^7.0.0",
    "xml2js": "^0.6.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/pixelmatch": "^5.2.6",
    "@types/pngjs": "^6.0.4",
    "@types/xml2js": "^0.4.14",
    "rimraf": "^6.1.3",
    "typescript": "^5.3.3"
  }
}
